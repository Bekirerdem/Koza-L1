# ============================================
# kozalak-l1 Environment Variables
# ============================================
# Bu dosyayı kopyalayıp `.env` olarak adlandırın
# `.env` dosyası ASLA git'e commit edilmez (.gitignore'da)
# ============================================

# ---- Deploy Wallet (Fuji testnet için) ----
# UYARI: Mainnet private key'i ASLA buraya koyma. Sadece testnet için.
# Production deployment için Foundry Cast Wallet (encrypted keystore) veya hardware wallet kullan.
PRIVATE_KEY=

# Deployer adres (sanity check için, opsiyonel)
DEPLOYER_ADDRESS=

# ---- RPC URLs ----
# Default değerler foundry.toml'da var, sadece custom RPC kullanırsan override için.
# FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
# AVAX_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# ---- Block Explorer (Routescan) ----
# Snowtrace.io artık Routescan altyapısında çalışıyor. routescan.io'dan
# ücretsiz hesap aç, API key oluştur (`rs_` prefix'li). foundry.toml
# `[etherscan]` bölümünden okur, ama verify çağrılarında EXPLICIT
# `--verifier-url` + `--etherscan-api-key` flag'leri kullanmak lessons.md'de
# belgelenmiş güvenli pattern (toml interpolation flaky).
SNOWTRACE_API_KEY=

# ---- ICM / Teleporter ----
# Avalanche Teleporter messenger — tüm L1'lerde deterministic adres
TELEPORTER_MESSENGER_ADDRESS=0x253b2784c75e510dD0fF1da844684a1aC0aa5fcf

# ---- Template 2 (ERC-721 KozaCollection) Fuji deploy parametreleri ----
# Default'lar Sprint 2'de v0.2.0 deployment için kullanıldı.
# NFT_NAME=Koza Genesis
# NFT_SYMBOL=KOZA
# NFT_BASE_URI=ipfs://CHANGE_ME/
NFT_MAX_SUPPLY=
NFT_MINT_PRICE=
# NFT_ROYALTY_BPS=500          # %5
# NFT_OWNER=                   # boş → broadcaster
# NFT_ROYALTY_RECEIVER=        # boş → broadcaster

# ---- Custom L1 (Subnet-EVM) — kozaTestL1 yerel test L1 ----
# Phase 1 Sprint 3 (ICTT bridge) için Avalanche CLI ile WSL'de spawn edilen
# yerel test L1. RPC URL Avalanche CLI session'a bağlı (port 9654 default,
# blockchain ID `chain.json`'da sabit ama her network clean'de değişir).
# WSL'de: `avalanche blockchain describe kozaTestL1` çalıştır → bilgileri al.
KOZA_TEST_L1_RPC_URL=
KOZA_TEST_L1_CHAIN_ID=9999

# ---- Sprint 3 ICTT bridge deploy parametreleri ----
# Home (Fuji) — script'te default'lar atanmış, override için doldur:
# HOME_TELEPORTER_REGISTRY=0xF86Cb19Ad8405AEFa7d09C778215D2Cb6eBfB228   # Fuji resmi
# HOME_TELEPORTER_MANAGER=                                              # boş → broadcaster (production: multisig)
# HOME_MIN_TELEPORTER_VERSION=1
# HOME_TOKEN_ADDRESS=0x06451DD4Fb8ebFC19870DacC9568f4364D2A2eB0         # KGAS v0.1.0
# HOME_TOKEN_DECIMALS=18

# Remote (kozaTestL1 veya başka hedef L1) — `avalanche blockchain describe` çıktısından
REMOTE_TELEPORTER_REGISTRY=
# REMOTE_TELEPORTER_MANAGER=                                            # boş → broadcaster (production: multisig)
# REMOTE_MIN_TELEPORTER_VERSION=1

# Fuji C-Chain blockchain ID (statik, Warp.getBlockchainID() ile alınır)
REMOTE_TOKEN_HOME_BLOCKCHAIN_ID=0x7fc93d85c6d62c5b2ac0b519c87010ea5294012d1e407030d6acd0021cac10d5
# REMOTE_TOKEN_HOME_DECIMALS=18    # KGAS 18 decimals

# KozaTokenHome deploy edildikten sonra doldurulur:
REMOTE_TOKEN_HOME_ADDRESS=

# Token meta (varsayılan: Wrapped Koza Gas / wKGAS / 18 decimals)
# REMOTE_TOKEN_NAME=Wrapped Koza Gas
# REMOTE_TOKEN_SYMBOL=wKGAS
# REMOTE_TOKEN_DECIMALS=18
